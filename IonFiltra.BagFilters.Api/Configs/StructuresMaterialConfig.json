{
    "lookup_name": "StructuresMaterialConfig",
    "display_name": "Structures Material Configuration",
    "setDefaultEnabled": false,

    "columns": [ "id", "material", "density", "rateperkg" ],

    "columnLabels": {
        "material": "Material",
        "density": "Density (kg/m3)",
        "rateperkg": "Rate (₹/Kg)"
    },

    "formFields": [
        {
            "name": "material",
            "label": "Material",
            "type": "text",
            "required": true,
            "placeholder": "Enter material name"
        },
        {
            "name": "density",
            "label": "Density (kg/m3)",
            "type": "number",
            "required": false,
            "placeholder": "Enter density",
            "min": 0,
            "step": 0.01
        },
        {
            "name": "rateperkg",
            "label": "Rate (₹/Kg)",
            "type": "number",
            "required": true,
            "placeholder": "Enter rate per kg",
            "min": 0,
            "step": 0.01
        }
    ],

    "idField": "id",

    "searchPlaceholder": "Search Structures Materials...",
    "addButtonText": "Add Structures Material",

    "formTitle": {
        "add": "Add Structures Material",
        "edit": "Edit Structures Material"
    },

    "crossTableTriggers": [
        {
            "condition": {
                "field": "material",
                "value": "IS2062"
            },
            "triggerFields": [ "rateperkg" ],
            "targets": [
                {
                    "table": "BillOfMaterialRates",
                    "setField": "rate",
                    "valueFrom": "rateperkg",
                    "filterField": "itemkey",
                    "includeKeys": [ "structure" ]
                }
            ]
        }
    ],

    "apiEndpoints": {
        "getAll": "/views/StructuresMaterialConfig",
        "add": "/views/StructuresMaterialConfig",
        "update": "/views/StructuresMaterialConfig/{id}",
        "delete": "/views/StructuresMaterialConfig/{id}"
    }
}
